# Re:Earth Classic Backend Environment Variables
#
# Values are stored in 1Password (vault: "Visualizer", item: "Classic BE secrets OSS").
# Run with `op inject -i app.env -o .env` to resolve secrets into .env,
# or wrap the Go process directly: `op run --env-file=app.env -- go run ./cmd/reearth`.

# Auth0
REEARTH_AUTH0_DOMAIN="op://Visualizer/Classic BE secrets OSS/add more/REEARTH_AUTH0_DOMAIN"
REEARTH_AUTH0_AUDIENCE="op://Visualizer/Classic BE secrets OSS/add more/REEARTH_AUTH0_AUDIENCE"
REEARTH_AUTH0_WEBCLIENTID="op://Visualizer/Classic BE secrets OSS/add more/REEARTH_AUTH0_WEBCLIENTID"

# Database
REEARTH_DB_ACCOUNT="op://Visualizer/Classic BE secrets OSS/add more/REEARTH_DB_ACCOUNT"
